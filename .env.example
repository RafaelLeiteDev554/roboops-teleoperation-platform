# RoboOps — example environment (safe to commit; no real secrets).
#
# Frontend (Vite): copy these lines to frontend/operator-console/.env.local
#   cp frontend/operator-console/.env.example frontend/operator-console/.env.local
VITE_API_BASE_URL=http://localhost:5157

# Backend (ASP.NET Core): set as environment variables, User Secrets, or Docker.
# Use "__" for nested config keys. Generate a long random string for non-local use.
# Auth__SigningKey=change-me-to-a-long-random-string
